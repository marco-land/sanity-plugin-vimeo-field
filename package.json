{
  "name": "sanity-plugin-vimeo-field",
  "version": "2.2.0",
  "description": "",
  "keywords": [
    "sanity",
    "sanity-plugin"
  ],
  "homepage": "https://github.com/marco-land/sanity-plugin-vimeo-field#readme",
  "bugs": {
    "url": "https://github.com/marco-land/sanity-plugin-vimeo-field/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/marco-land/sanity-plugin-vimeo-field.git"
  },
  "type": "module",
  "license": "MIT",
  "author": "Marco Land <mail@marco.land>",
  "packageManager": "pnpm@10.12.4",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "sanity.json",
    "src",
    "v2-incompatible.js"
  ],
  "scripts": {
    "build": "plugin-kit verify-package --silent && pkg-utils build --strict --check --clean",
    "link-watch": "plugin-kit link-watch",
    "lint": "eslint .",
    "prepublishOnly": "npm run build",
    "watch": "pkg-utils watch --strict"
  },
  "dependencies": {
    "@sanity/incompatible-plugin": "^1.0.4",
    "@sanity/studio-secrets": "^4.0.2"
  },
  "devDependencies": {
    "@sanity/icons": "^3",
    "@sanity/pkg-utils": "^10",
    "@sanity/plugin-kit": "^4",
    "@sanity/ui": "^3",
    "@types/react": "^18",
    "@typescript-eslint/eslint-plugin": "^8",
    "@typescript-eslint/parser": "^8",
    "eslint": "^8.56.0",
    "eslint-config-sanity": "^7.1.4",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "react": "^18",
    "react-dom": "^18",
    "react-is": "^18",
    "sanity": "^5",
    "semantic-release": "^25.0.3",
    "styled-components": "^6",
    "typescript": "^5.3.3"
  },
  "peerDependencies": {
    "@sanity/icons": ">=3",
    "@sanity/ui": ">=3",
    "react": ">=18",
    "sanity": ">=5"
  },
  "engines": {
    "node": ">=18"
  },
  "sanityPlugin": {
    "verifyPackage": {}
  }
}
